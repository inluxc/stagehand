# Playwright Framework - Environment Variables
# Copy this file to .env.{environment} (e.g., .env.local, .env.dev) and fill in the values.
# Environment variables override values from environments.json.
# Precedence: env vars > .env.{environment} file > environments.json

# ─── General ────────────────────────────────────────────────────────────────────

# Active environment name (local, dev, test, stg, prod)
PW_ENVIRONMENT=local

# ─── OpenAPI Configuration ──────────────────────────────────────────────────────

# Path to OpenAPI spec file (local path or remote URL)
PW_OPENAPI_SPEC_PATH=./specs/api.yaml

# Base URL override for API calls (takes precedence over spec server URLs)
PW_OPENAPI_BASE_URL=http://localhost:3000

# ─── Database Configuration ─────────────────────────────────────────────────────

# Database type: postgresql, mysql, mssql, or sqlite
PW_DB_TYPE=postgresql

# Database host address
PW_DB_HOST=localhost

# Database port number
PW_DB_PORT=5432

# Database name
PW_DB_NAME=testdb

# Database username
PW_DB_USERNAME=test

# Database password
PW_DB_PASSWORD=test

# ─── Kafka Configuration ───────────────────────────────────────────────────────

# Comma-separated list of Kafka broker addresses (host:port)
PW_KAFKA_BROKERS=localhost:9092

# ─── Redis Configuration ───────────────────────────────────────────────────────

# Redis server host address
PW_REDIS_HOST=localhost

# Redis server port number
PW_REDIS_PORT=6379

# Redis server password (leave empty if no auth required)
PW_REDIS_PASSWORD=

# Key prefix for test-scoped isolation (keys with this prefix are flushed on teardown)
PW_REDIS_KEY_PREFIX=test:

# ─── Mobilewright Configuration ────────────────────────────────────────────────

# Target platform: ios or android
PW_MOBILE_PLATFORM=ios

# Application bundle identifier (e.g., com.example.app)
PW_MOBILE_BUNDLE_ID=com.example.app

# Target device or simulator name (e.g., iPhone 15, Pixel 8)
PW_MOBILE_DEVICE_NAME=iPhone 15

# Path to the application binary (.app for iOS, .apk for Android)
PW_MOBILE_APP_PATH=./apps/example.app
