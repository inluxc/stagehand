# Playwright Framework - Dev Environment Configuration
# Copy this file to .env.dev and fill in the values for the dev environment.
# These values override environments.json but are overridden by system env vars.

# ─── General ────────────────────────────────────────────────────────────────────

# Active environment name
PW_ENVIRONMENT=dev

# ─── OpenAPI Configuration ──────────────────────────────────────────────────────

# Remote OpenAPI spec URL for dev environment
PW_OPENAPI_SPEC_PATH=https://api.dev.example.com/openapi.json

# Dev API server URL
PW_OPENAPI_BASE_URL=https://api.dev.example.com

# ─── Database Configuration ─────────────────────────────────────────────────────

# Database type
PW_DB_TYPE=postgresql

# Dev database host
PW_DB_HOST=dev-db.example.com

# Dev database port
PW_DB_PORT=5432

# Dev database name
PW_DB_NAME=testdb

# Dev database username
PW_DB_USERNAME=dev_user

# Dev database password (retrieve from secrets provider or set here)
PW_DB_PASSWORD=

# ─── Kafka Configuration ───────────────────────────────────────────────────────

# Dev Kafka broker addresses (comma-separated)
PW_KAFKA_BROKERS=kafka.dev.example.com:9092

# ─── Redis Configuration ───────────────────────────────────────────────────────

# Dev Redis host
PW_REDIS_HOST=redis.dev.example.com

# Dev Redis port
PW_REDIS_PORT=6379

# Dev Redis password
PW_REDIS_PASSWORD=

# Key prefix for test isolation in dev
PW_REDIS_KEY_PREFIX=test:dev:

# ─── Mobilewright Configuration ────────────────────────────────────────────────

# Target platform for dev testing
PW_MOBILE_PLATFORM=ios

# Dev application bundle identifier
PW_MOBILE_BUNDLE_ID=com.example.app.dev

# Device name for dev testing
PW_MOBILE_DEVICE_NAME=iPhone 15

# Path to dev application binary
PW_MOBILE_APP_PATH=./apps/example-dev.app
