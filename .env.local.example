# Playwright Framework - Local Environment Configuration
# Copy this file to .env.local and fill in the values for local development.
# These values override environments.json but are overridden by system env vars.

# ─── General ────────────────────────────────────────────────────────────────────

# Active environment name
PW_ENVIRONMENT=local

# ─── OpenAPI Configuration ──────────────────────────────────────────────────────

# Path to local OpenAPI spec file
PW_OPENAPI_SPEC_PATH=./specs/api.yaml

# Local API server URL
PW_OPENAPI_BASE_URL=http://localhost:3000

# ─── Database Configuration ─────────────────────────────────────────────────────

# Database type: postgresql, mysql, mssql, or sqlite
PW_DB_TYPE=postgresql

# Local database host
PW_DB_HOST=localhost

# Local database port
PW_DB_PORT=5432

# Local database name
PW_DB_NAME=testdb

# Local database username
PW_DB_USERNAME=test

# Local database password
PW_DB_PASSWORD=test

# ─── Kafka Configuration ───────────────────────────────────────────────────────

# Local Kafka broker address (comma-separated for multiple brokers)
PW_KAFKA_BROKERS=localhost:9092

# ─── Redis Configuration ───────────────────────────────────────────────────────

# Local Redis host
PW_REDIS_HOST=localhost

# Local Redis port
PW_REDIS_PORT=6379

# Local Redis password (leave empty if no auth)
PW_REDIS_PASSWORD=

# Key prefix for test isolation
PW_REDIS_KEY_PREFIX=test:

# ─── Mobilewright Configuration ────────────────────────────────────────────────

# Target platform for local testing
PW_MOBILE_PLATFORM=ios

# Application bundle identifier
PW_MOBILE_BUNDLE_ID=com.example.app

# Local simulator/emulator device name
PW_MOBILE_DEVICE_NAME=iPhone 15

# Path to local application binary
PW_MOBILE_APP_PATH=./apps/example.app
